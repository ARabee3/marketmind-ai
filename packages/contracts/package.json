{
  "name": "@marketmind/contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "check": "npm run typecheck && node scripts/validate-examples.mjs && npm run check:policy && npm run check:snapshot && npm run check:python",
