# Supported values: mock, openai, gemini_dev, openrouter.
AI_PROVIDER_MODE=mock
AI_REQUEST_TIMEOUT_MS=30000

# Local service command:
# uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

# Required only when AI_PROVIDER_MODE=openai.
OPENAI_API_KEY=
OPENAI_MODEL=

# Required only when AI_PROVIDER_MODE=gemini_dev.
GEMINI_API_KEY=
GEMINI_MODEL=

# Required only when AI_PROVIDER_MODE=openrouter.
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=

# Embedding provider configuration
# Supported values: openai, fake.
# Default production model is text-embedding-3-large (3072 dims).
# Use text-embedding-3-small (1536 dims) for faster/cheaper local development.
EMBEDDING_PROVIDER_MODE=fake
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_TIMEOUT_MS=60000

# Qdrant vector database configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=marketing_knowledge_v1
QDRANT_API_KEY=
QDRANT_TIMEOUT_MS=10000
QDRANT_USE_GRPC=false
