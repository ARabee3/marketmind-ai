# =============================================================================
# MarketMind API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
# cp .env.example .env
# =============================================================================

# ---------- Application ----------
NODE_ENV=development
PORT=3001

# ---------- PostgreSQL ----------
# Connection URL for Prisma and the NestJS app.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://marketmind:marketmind_dev@localhost:5432/marketmind_dev?schema=public

# ---------- JWT (for Auth module — Issue #5) ----------
JWT_ACCESS_SECRET=change-me-to-a-secure-random-access-secret
JWT_REFRESH_SECRET=change-me-to-a-secure-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS / Cookies ----------
# The origin of the frontend web app. Required for credentialed CORS.
WEB_ORIGIN=http://localhost:3000
# Set to true in production to require HTTPS for the refresh-token cookie.
COOKIE_SECURE=false
# Cookie SameSite policy: lax | strict | none
COOKIE_SAME_SITE=lax

# ---------- Internal services ----------
AI_SERVICE_BASE_URL=http://localhost:8000
DISCOVERY_SEARCH_TIMEOUT_MS=8000
AI_REQUEST_TIMEOUT_MS=30000
AI_PROVIDER_RETRY_DELAY_MS=3000
DISCOVERY_RESEARCH_TIMEOUT_MS=180000
DISCOVERY_TRIAGE_TIMEOUT_MS=120000

# ---------- Search providers ----------
SERPAPI_KEY=
# Either APIFY_TOKEN or APIFY_API_KEY works locally.
APIFY_TOKEN=

# ---------- Facebook public Page enrichment ----------
# Disabled by default. Uses only owner-submitted public business Page URLs.
DISCOVERY_FACEBOOK_ENRICHMENT_ENABLED=false
DISCOVERY_FACEBOOK_POSTS_ENABLED=false
APIFY_FACEBOOK_PAGES_ACTOR_ID=apify~facebook-pages-scraper
APIFY_FACEBOOK_POSTS_ACTOR_ID=apify~facebook-posts-scraper
DISCOVERY_FACEBOOK_MAX_PAGES=1
DISCOVERY_FACEBOOK_MAX_POSTS=5
DISCOVERY_FACEBOOK_TIMEOUT_MS=60000
DISCOVERY_FACEBOOK_SESSION_MAX_CHARGE_USD=0.05
DISCOVERY_FACEBOOK_PAGES_MAX_CHARGE_USD=0.02
DISCOVERY_FACEBOOK_POSTS_MAX_CHARGE_USD=0.03

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
DISCOVERY_WORKER_ENABLED=true
DISCOVERY_WORKER_CONCURRENCY=2

# ---------- Google OAuth (Issue #48) ----------
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Backend callback URL registered in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ---------- Transactional mail ----------
# Use mock locally. Use smtp in development and production with any SMTP host
# (Gmail, Mailgun, SES, etc.). The SMTP_* values are required when
# MAIL_PROVIDER=smtp and ignored otherwise.
MAIL_PROVIDER=smtp
# Standard SMTP connection. Gmail example shown — use an app password, not
# your account password, when the sender is a Gmail address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abdulazem.rabie@gmail.com
SMTP_PASS=
# Address shown as the From sender. Some providers (e.g. Gmail) require this
# to match SMTP_USER; others (e.g. Mailgun, SES) allow a verified sender.
MAIL_FROM=no-reply@example.com
APP_URL=http://localhost:3000

# ---------- AI provider passthrough ----------
# FastAPI owns provider calls. Keep these here only if local scripts or
# diagnostics need to inspect the chosen model from the API workspace.
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=
