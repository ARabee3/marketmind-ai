# =============================================================================
# MarketMind API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
# cp .env.example .env
# =============================================================================

# ---------- Application ----------
NODE_ENV=development
PORT=3001

# ---------- PostgreSQL ----------
# Connection URL for Prisma and the NestJS app.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://marketmind:marketmind_dev@localhost:5432/marketmind_dev?schema=public

# ---------- JWT (for Auth module — Issue #5) ----------
JWT_ACCESS_SECRET=change-me-to-a-secure-random-access-secret
JWT_REFRESH_SECRET=change-me-to-a-secure-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS / Cookies ----------
# The origin of the frontend web app. Required for credentialed CORS.
WEB_ORIGIN=http://localhost:3000
# Set to true in production to require HTTPS for the refresh-token cookie.
COOKIE_SECURE=false
# Cookie SameSite policy: lax | strict | none
COOKIE_SAME_SITE=lax

# ---------- Internal services ----------
AI_SERVICE_BASE_URL=http://localhost:8000
DISCOVERY_SEARCH_TIMEOUT_MS=8000
AI_REQUEST_TIMEOUT_MS=30000
DISCOVERY_RESEARCH_TIMEOUT_MS=180000

# ---------- Search providers ----------
SERPAPI_KEY=
# Either APIFY_TOKEN or APIFY_API_KEY works locally.
APIFY_TOKEN=

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
DISCOVERY_WORKER_ENABLED=true
DISCOVERY_WORKER_CONCURRENCY=2

# ---------- AI provider passthrough ----------
# FastAPI owns provider calls. Keep these here only if local scripts or
# diagnostics need to inspect the chosen model from the API workspace.
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=
